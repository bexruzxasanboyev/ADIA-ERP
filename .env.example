# ADIA ERP — muhit o'zgaruvchilari namunasi.
# Nusxa oling:  cp .env.example .env  — va haqiqiy qiymatlarni to'ldiring.
# .env fayli git'ga yuklanmaydi; .env.example yuklanadi.

# --- Poster POS API (https://dev.joinposter.com) ---
POSTER_ACCOUNT=adia
POSTER_APP_ID=4884
POSTER_APP_SECRET=
POSTER_TOKEN=
# Shared secret embedded in the Poster webhook URL (path or ?secret=). Until
# Poster documents an HMAC signature, this token guards
# POST /api/integrations/poster/webhook against unauthenticated callers.
# Generate a random unguessable value (32+ bytes); rotate when leaked.
POSTER_WEBHOOK_SECRET=

# --- Backend API (apps/api) ---
NODE_ENV=development
PORT=3001
# Allowed CORS origin for the web client (single-origin — not a public API).
# Production: set to the deployed web URL (e.g. https://erp.example.com).
WEB_ORIGIN=http://localhost:5173

# --- PostgreSQL ---
# Lokal dev (Unix socket, peer auth): postgres:///adia_erp_dev?host=/var/run/postgresql
# TCP variant: postgres://<user>:<pass>@localhost:5432/adia_erp_dev
DATABASE_URL=

# --- Auth ---
# Sprint-3 (ADR-0005): split tokens. Access = short-lived JWT, refresh =
# opaque 32-byte hex with server-side revocation (refresh_tokens table).
JWT_SECRET=
# Access token TTL — 1 hour (3600s). Replaces the old single 12-hour JWT.
JWT_ACCESS_TTL_SECONDS=3600
# Refresh token TTL — 30 days. Rotated on every /api/auth/refresh.
JWT_REFRESH_TTL_DAYS=30
# Deprecated alias of JWT_ACCESS_TTL_SECONDS — kept for one release so old
# .env files do not break. Will be removed in Sprint-4.
JWT_EXPIRES_IN_SECONDS=3600

# --- Telegram bot (Grammy) ---
# M9 — outbound-only bot used by the telegramOutbox worker.
# BOT_TOKEN: from @BotFather. Empty -> the outbox worker is not started
# (the API still records notifications; Grammy is simply skipped).
# BOT_USERNAME: bot handle without the leading @ (for help text / deep links).
BOT_TOKEN=
BOT_USERNAME=

# --- Vertex AI Gemini (Faza-2 AI assistant) ---
# Google Cloud service account JSON path. The JSON file MUST be gitignored;
# only the path goes here. Empty -> the AI assistant is not started.
# Region: europe-west1 (Belgium) for low latency to Hetzner.
# Model: gemini-2.5-flash for chat (function calling + cheap latency).
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=
VERTEX_REGION=europe-west1
VERTEX_MODEL=gemini-2.5-flash
