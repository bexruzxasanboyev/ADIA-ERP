# API base URL for the ADIA ERP backend (apps/api — default port 3001)
VITE_API_BASE_URL=http://localhost:3001

# EPIC 3.2 — Telegram bot username (no leading @). When set, the
# "TG ulash" dialog builds a https://t.me/<bot>?start=<token> deep link.
# Leave empty to show the raw /start command instead.
VITE_TELEGRAM_BOT_USERNAME=
