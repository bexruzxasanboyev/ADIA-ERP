# ADIA ERP — muhit o'zgaruvchilari namunasi.
# Nusxa oling:  cp .env.example .env  — va haqiqiy qiymatlarni to'ldiring.
# .env fayli git'ga yuklanmaydi; .env.example yuklanadi.

# --- Poster POS API (https://dev.joinposter.com) ---
POSTER_ACCOUNT=adia
POSTER_APP_ID=4884
POSTER_APP_SECRET=
POSTER_TOKEN=
# Shared secret embedded in the Poster webhook URL (path or ?secret=). Until
# Poster documents an HMAC signature, this token guards
# POST /api/integrations/poster/webhook against unauthenticated callers.
# Generate a random unguessable value (32+ bytes); rotate when leaked.
POSTER_WEBHOOK_SECRET=

# --- Backend API (apps/api) ---
NODE_ENV=development
PORT=3001
# Allowed CORS origins for the web client. Comma-separated allowlist —
# local dev and tests need both `localhost` and `127.0.0.1`, so keep both.
# Production: set to the deployed web URL(s) (e.g. https://erp.example.com).
# Bug-MAJ-02 (F4.11) — a single-origin string broke whichever host was not
# listed.
WEB_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# --- PostgreSQL ---
# Lokal dev (Unix socket, peer auth): postgres:///adia_erp_dev?host=/var/run/postgresql
# TCP variant: postgres://<user>:<pass>@localhost:5432/adia_erp_dev
DATABASE_URL=

# --- Auth ---
# Sprint-3 (ADR-0005): split tokens. Access = short-lived JWT, refresh =
# opaque 32-byte hex with server-side revocation (refresh_tokens table).
JWT_SECRET=
# Access token TTL — 1 hour (3600s). Replaces the old single 12-hour JWT.
JWT_ACCESS_TTL_SECONDS=3600
# Refresh token TTL — 30 days. Rotated on every /api/auth/refresh.
JWT_REFRESH_TTL_DAYS=30
# Deprecated alias of JWT_ACCESS_TTL_SECONDS — kept for one release so old
# .env files do not break. Will be removed in Sprint-4.
JWT_EXPIRES_IN_SECONDS=3600

# --- Telegram bot (Grammy) ---
# M9 — outbound-only bot used by the telegramOutbox worker.
# BOT_TOKEN: from @BotFather. Empty -> the outbox worker is not started
# (the API still records notifications; Grammy is simply skipped).
# BOT_USERNAME: bot handle without the leading @ (for help text / deep links).
BOT_TOKEN=
BOT_USERNAME=

# --- Vertex AI Gemini (Faza-2 AI assistant, ADR-0006 / ADR-0008) ---
# Google Cloud service account JSON path. The JSON file MUST be gitignored;
# only the path goes here. Region: europe-west1 (Belgium) for low latency to
# Hetzner. Model: gemini-2.5-flash for chat (function calling + cheap latency).
#
# Graceful degrade: the assistant is ENABLED only when BOTH VERTEX_PROJECT_ID
# and GOOGLE_APPLICATION_CREDENTIALS are non-empty (and NODE_ENV != test).
# When either is empty, POST /api/assistant/query returns 503 VERTEX_UNAVAILABLE
# ("AI yordamchi vaqtincha mavjud emas") and the rest of the ERP is unaffected.
# Smoke-test the live wiring with: npm run vertex:test -w @adia/backend
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=
VERTEX_REGION=europe-west1
VERTEX_MODEL=gemini-2.5-flash
# Token / tool-call budgets (optional — defaults shown). maxInputTokens also
# bounds the per-message char cap (~3 chars/token) at the route boundary.
VERTEX_MAX_INPUT_TOKENS=8000
VERTEX_MAX_OUTPUT_TOKENS=2000
VERTEX_MAX_TOOL_CALLS=5

# --- Forecasting sidecar (Faza-3 Sprint 4, ADR-0010) ---
# Prophet Python sidecar that fits sales forecasts once a day (cron 04:30).
# FORECASTER_URL: base URL of the sidecar (compose default: http://forecaster:8000;
# local: http://127.0.0.1:8000).
# FORECASTER_SHARED_SECRET: random hex string; sidecar verifies with timing-safe
# compare. Both must be set to enable the feature (cron, /api/forecasts, AI tool).
# FORECASTER_HORIZON_DAYS: how many days ahead to forecast (1..30, default 14).
# FORECASTER_BATCH_SIZE: items per HTTP request (default 50; max 100 by sidecar).
# FORECASTER_REQUEST_TIMEOUT_MS: per-request timeout (default 120000 = 2 min).
FORECASTER_URL=
FORECASTER_SHARED_SECRET=
FORECASTER_HORIZON_DAYS=14
FORECASTER_BATCH_SIZE=50
FORECASTER_REQUEST_TIMEOUT_MS=120000

# --- Yandex Cloud (Faza-4 F4.2 — voice pipeline, ADR-0013) ---
# YANDEX_OAUTH_TOKEN: long-lived OAuth token from
#   https://oauth.yandex.com/authorize?response_type=token&client_id=1a6990aa636648e9b2ef855fa7bec2fb
# The IAM token is minted on demand (12h lifetime, refreshed automatically).
# YANDEX_FOLDER_ID / YANDEX_BUCKET / YANDEX_SA_* are produced by the
# `npm run yandex:bootstrap -w @adia/backend` provisioning script — copy
# the printed snippet here. The feature is enabled only when all of the
# OAuth token, folder id, and bucket name are set.
YANDEX_OAUTH_TOKEN=
YANDEX_FOLDER_ID=
YANDEX_BUCKET=
YANDEX_SA_ACCESS_KEY=
YANDEX_SA_SECRET_KEY=
